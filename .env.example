# Copy this file to .env and fill in the values for local development.
# In Vercel, add these as Environment Variables in the project settings.

# Groq AI API Key (required for chatbot)
GROQ_API_KEY=your_groq_api_key_here

# JWT Secret (required for auth routes)
JWT_SECRET=your_jwt_secret_here

# PostgreSQL Connection (optional - used by auth & session routes)
NEON_DATABASE_URL=your_neon_db_url_here

# Allowed CORS origins (comma-separated, leave blank to allow all)
ALLOWED_ORIGINS=https://your-vercel-app.vercel.app
